# Скопируйте в .env и заполните значения. Файл .env не коммитится (см. .gitignore).

# HTTP
HTTP_ADDR=:8080

# База данных
DATABASE_URL=postgres://postgres:postgres@localhost:5432/petio?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production

# KServe (ML, опционально)
KSERVE_URL=

# Yandex Object Storage (S3-совместимый API) — обязательны для загрузки фото (upload)
# Тип авторизации: статический ключ доступа (Static Access Key) — пара Key ID + Secret.
# Где взять: Консоль Yandex Cloud → Сервисные аккаунты → выбрать аккаунт → «Создать ключ» → «Создать статический ключ доступа». Скачается JSON с key_id и secret.
S3_BUCKET=your-bucket-name
S3_REGION=ru-central1
S3_ENDPOINT=https://storage.yandexcloud.net
# Публичный URL бакета (опционально), например: https://storage.yandexcloud.net/your-bucket
S3_BASE_URL=

# Статический ключ доступа: Key ID и Secret из консоли (не IAM-токен и не API-ключ сервиса)
AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-secret

# Альтернативные имена (если не заданы AWS_*)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
